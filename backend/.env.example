DB_PROVIDER=sqlite
SQLITE_DB_PATH=./database.sqlite

# Firebase/Firestore:
# DB_PROVIDER=firebase
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or set these directly on Render instead of uploading a JSON file:
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

JWT_SECRET=change_this_secret
CORS_ORIGIN=

# Email verification and password reset.
APP_NAME=Steam Manager
EMAIL_CODE_TTL_MINUTES=10
ALLOW_DEV_EMAIL_CODE=false

# Configure SMTP to send real emails.
# Gmail requires an App Password, not your normal Gmail password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Steam Manager <your-email@gmail.com>"

# Only for local development if you want to show the code on the register page.
# Do not enable this in production.
# ALLOW_DEV_EMAIL_CODE=true
